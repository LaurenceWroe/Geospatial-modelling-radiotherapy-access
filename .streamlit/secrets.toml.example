# Copy this file to secrets.toml and fill in your credentials.
# secrets.toml is gitignored and must never be committed.

# TravelTime API — required only for travel-time routing (driving / public transport).
# Free tier available at https://traveltime.com
[traveltime]
app_id = "your_app_id_here"
api_key = "your_api_key_here"
